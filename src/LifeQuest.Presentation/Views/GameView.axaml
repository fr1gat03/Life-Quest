<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LifeQuest.Presentation.ViewModels"
             x:Class="LifeQuest.Presentation.Views.GameView"
             x:DataType="vm:GameViewModel"
             Background="#0F0F1A" FontFamily="Segoe UI">

    <Grid RowDefinitions="Auto, Auto, *">

        <!-- HEADER -->
        <Border Grid.Row="0" Padding="25,18">
            <Border.Background>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                    <GradientStop Color="#1a1a2e" Offset="0"/>
                    <GradientStop Color="#16213e" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid ColumnDefinitions="Auto, *, Auto">

                <!-- Аватар + ім'я -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            Spacing="15" VerticalAlignment="Center">
                    <Border Width="64" Height="64" CornerRadius="32"
                            BoxShadow="0 0 20 0 #4489B4FA">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                <GradientStop Color="#89B4FA" Offset="0"/>
                                <GradientStop Color="#CBA6F7" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="{Binding AvatarText, Mode=OneWay}"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="#11111B"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel VerticalAlignment="Center" Spacing="4">
                        <TextBlock Text="{Binding PlayerName, Mode=OneWay}"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="#CDD6F4"/>
                        <Border Background="#313244" CornerRadius="10"
                                Padding="8,3" HorizontalAlignment="Left">
                            <TextBlock Text="{Binding PlayerLevel, Mode=OneWay}"
                                       FontSize="12" Foreground="#89B4FA"
                                       FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <!-- HP / XP бари -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center"
                            Spacing="10" Margin="30,0">

                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBlock Text="HP" Foreground="#CDD6F4"
                                   FontWeight="Bold" FontSize="13"
                                   Width="28" VerticalAlignment="Center"/>
                        <ProgressBar Value="{Binding CurrentHp, Mode=OneWay}"
                                     Maximum="{Binding MaxHp, Mode=OneWay}"
                                     Width="300" Height="14"
                                     Foreground="#FF4D57" Background="#2a1a1e"
                                     CornerRadius="8"/>
                        <TextBlock Text="{Binding HpText, Mode=OneWay}"
                                   Foreground="#6C7086" FontSize="12"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBlock Text="XP" Foreground="#CDD6F4"
                                   FontWeight="Bold" FontSize="13"
                                   Width="28" VerticalAlignment="Center"/>
                        <ProgressBar Value="{Binding CurrentXp, Mode=OneWay}"
                                     Maximum="{Binding MaxXp, Mode=OneWay}"
                                     Width="300" Height="14"
                                     Foreground="#A6E3A1" Background="#1a2e1a"
                                     CornerRadius="8"/>
                        <TextBlock Text="{Binding XpText, Mode=OneWay}"
                                   Foreground="#6C7086" FontSize="12"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- Золото -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            Spacing="6" VerticalAlignment="Center">
                    <TextBlock Text="💰" FontSize="22" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Gold, Mode=OneWay}"
                               FontSize="24" FontWeight="Bold"
                               Foreground="#FFD700" VerticalAlignment="Center"/>
                </StackPanel>

            </Grid>
        </Border>

        <!-- РОЗДІЛЬНИК -->
        <Border Grid.Row="1" Height="1" Background="#63169D"/>

        <!-- КОНТЕНТ -->
        <ScrollViewer Grid.Row="2" Margin="25,20">
            <StackPanel Spacing="0">

                <!-- Заголовок + кнопки -->
                <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,20">
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                Spacing="12" VerticalAlignment="Center">
                        <TextBlock Text="⚔️" FontSize="22"/>
                        <TextBlock Text="Активні квести"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="#CDD6F4" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                        <Button Command="{Binding OpenTavernCommand}"
                                CornerRadius="20" Padding="16,8">
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                    <GradientStop Color="#CBA6F7" Offset="0"/>
                                    <GradientStop Color="#89B4FA" Offset="1"/>
                                </LinearGradientBrush>
                            </Button.Background>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="🧙‍♂️" VerticalAlignment="Center"/>
                                <TextBlock Text="Таверна" FontWeight="Bold"
                                           Foreground="#11111B" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding OpenCreateQuestCommand}"
                                CornerRadius="20" Padding="16,8">
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                    <GradientStop Color="#A6E3A1" Offset="0"/>
                                    <GradientStop Color="#94E2D5" Offset="1"/>
                                </LinearGradientBrush>
                            </Button.Background>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="✨" VerticalAlignment="Center"/>
                                <TextBlock Text="Новий квест" FontWeight="Bold"
                                           Foreground="#11111B" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding OpenSettingsCommand}"
                                CornerRadius="20" Padding="16,8"
                                Background="#313244">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="⚙️" VerticalAlignment="Center"/>
                                <TextBlock Text="Налаштування" FontWeight="Bold"
                                           Foreground="#CDD6F4" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Список квестів -->
                <ItemsControl ItemsSource="{Binding ActiveQuests}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,10" CornerRadius="14"
                                    BoxShadow="0 2 12 0 #00000040"
                                    Background="#1e1e2e">

                                <Grid ColumnDefinitions="*, Auto" Margin="20,14">

                                    <StackPanel Grid.Column="0" Spacing="8"
                                                VerticalAlignment="Center">

                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="16" FontWeight="SemiBold"
                                                   Foreground="#CDD6F4" TextWrapping="Wrap"/>

                                        <!-- Ghost badges -->
                                        <StackPanel Orientation="Horizontal" Spacing="14">

                                            <TextBlock Text="{Binding DifficultyLabel}"
                                                       FontSize="13" FontWeight="Bold"
                                                       Foreground="{Binding DifficultyColor}"
                                                       VerticalAlignment="Center"/>

                                            <TextBlock Text="·" Foreground="#45475A"
                                                       FontSize="16" VerticalAlignment="Center"/>

                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <TextBlock Text="✨" FontSize="12"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding RewardXp, StringFormat='{}{0} XP'}"
                                                           Foreground="#A6E3A1" FontSize="13"
                                                           FontWeight="SemiBold"/>
                                            </StackPanel>

                                            <TextBlock Text="·" Foreground="#45475A"
                                                       FontSize="16" VerticalAlignment="Center"/>

                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <TextBlock Text="💰" FontSize="12"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding RewardGold, StringFormat='{}{0} Gold'}"
                                                           Foreground="#F9E2AF" FontSize="13"
                                                           FontWeight="SemiBold"/>
                                            </StackPanel>

                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Кнопка виконати — колір залежить від складності -->
                                    <Button Grid.Column="1"
                                            Content="Виконати ✓"
                                            Command="{Binding CompleteCommand}"
                                            IsEnabled="{Binding !IsCompleted}"
                                            VerticalAlignment="Center"
                                            Margin="20,0,0,0"
                                            FontSize="13" FontWeight="Bold"
                                            Foreground="#11111B"
                                            CornerRadius="10" Padding="18,9"
                                            Background="{Binding DifficultyColor}"/>

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Версія внизу -->
                <TextBlock Text="Life Quest v0.0.1 — Froggy TEAM"
                           Foreground="#313244" FontSize="11"
                           HorizontalAlignment="Center"
                           Margin="0,30,0,10"/>
            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>