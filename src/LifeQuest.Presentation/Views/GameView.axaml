<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LifeQuest.Presentation.ViewModels"
             x:Class="LifeQuest.Presentation.Views.GameView"
             x:DataType="vm:GameViewModel"
             Background="#1E1E2E" FontFamily="Segoe UI">

    <Grid RowDefinitions="Auto, *">
        <Border Grid.Row="0" Background="#181825" Padding="20" CornerRadius="0,0,15,15" BoxShadow="0 5 15 0 #000000">
            <StackPanel Orientation="Horizontal" Spacing="20">
                <Border Width="80" Height="80" CornerRadius="40" Background="#89B4FA">
                    <TextBlock Text="😎" FontSize="40" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                
                <StackPanel VerticalAlignment="Center" Spacing="8">
                    <TextBlock Text="{Binding PlayerName, Mode=OneWay}" FontSize="22" FontWeight="Bold" Foreground="#CDD6F4"/>
                    <TextBlock Text="{Binding PlayerLevel, Mode=OneWay}" FontSize="16" Foreground="#A6ADC8"/>
                    
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="HP" Foreground="#F38BA8" FontWeight="Bold" Width="25"/>
                        <ProgressBar Value="{Binding CurrentHp, Mode=OneWay}" Maximum="{Binding MaxHp, Mode=OneWay}" Width="300" Height="15" Foreground="#F38BA8" Background="#313244"/>
                        <TextBlock Text="{Binding HpText, Mode=OneWay}" Foreground="#CDD6F4" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="XP" Foreground="#A6E3A1" FontWeight="Bold" Width="25"/>
                        <ProgressBar Value="{Binding CurrentXp, Mode=OneWay}" Maximum="{Binding MaxXp, Mode=OneWay}" Width="300" Height="15" Foreground="#A6E3A1" Background="#313244"/>
                        <TextBlock Text="{Binding XpText, Mode=OneWay}" Foreground="#CDD6F4" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
                
                <StackPanel VerticalAlignment="Center" Margin="100,0,0,0">
                    <TextBlock Text="💰 Золото" FontSize="18" Foreground="#F9E2AF" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding Gold, Mode=OneWay}" FontSize="28" FontWeight="Bold" Foreground="#F9E2AF" HorizontalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" Margin="20">
            <StackPanel Spacing="15">
                <TextBlock Text="⚔️ Активні Квести" FontSize="26" FontWeight="Bold" Foreground="#CDD6F4" Margin="0,10,0,10"/>
                
                <ItemsControl ItemsSource="{Binding ActiveQuests}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#313244" CornerRadius="10" Padding="15" Margin="0,0,0,10">
                                <Grid ColumnDefinitions="*, Auto">
                    
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="5">
                                        <TextBlock Text="{Binding Title}" FontSize="20" FontWeight="SemiBold" Foreground="#CDD6F4"/>
    
                                        <StackPanel Orientation="Horizontal" Spacing="15">
                                            <StackPanel Orientation="Horizontal" Spacing="5">
                                                <TextBlock Text="✨" FontSize="12" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding RewardXp, StringFormat='{}{0} XP'}" 
                                                           Foreground="#A6E3A1" FontSize="14" FontWeight="Medium"/>
                                            </StackPanel>
        
                                            <StackPanel Orientation="Horizontal" Spacing="5">
                                                <TextBlock Text="💰" FontSize="12" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding RewardGold, StringFormat='{}{0} Gold'}" 
                                                           Foreground="#F9E2AF" FontSize="14" FontWeight="Medium"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                    
                                    <Button Grid.Column="1" Content="Виконати" Command="{Binding CompleteCommand}" 
                                            IsEnabled="{Binding !IsCompleted}"
                                            FontSize="16" FontWeight="Bold" Background="#A6E3A1" Foreground="#11111B" 
                                            CornerRadius="8" Padding="15,10" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>