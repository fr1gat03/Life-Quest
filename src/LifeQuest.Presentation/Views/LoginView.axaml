<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LifeQuest.Presentation.ViewModels"
             x:Class="LifeQuest.Presentation.Views.LoginView"
             x:DataType="vm:LoginViewModel"
             Background="#1E1E2E">
             
    <Border Padding="40" VerticalAlignment="Center" HorizontalAlignment="Center" 
            Background="#181825" CornerRadius="15" BoxShadow="0 10 30 0 #000000">
        
        <StackPanel Spacing="15" Width="280">
            <TextBlock Text="⚔️" FontSize="50" HorizontalAlignment="Center"/>
            <TextBlock Text="Life Quest" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#CDD6F4"/>
            <TextBlock Text="Увійдіть, щоб продовжити" FontSize="14" HorizontalAlignment="Center" Foreground="#A6ADC8" Margin="0,0,0,10"/>

            <TextBlock Text="Логін" Foreground="#CDD6F4" FontSize="14"/>
            <TextBox Text="{Binding Username}" Watermark="Введіть ваш логін..." 
                     Background="#313244" Foreground="#CDD6F4" BorderThickness="0" CornerRadius="8"/>
            
            <TextBlock Text="Пароль" Foreground="#CDD6F4" FontSize="14" Margin="0,10,0,0"/>
            <TextBox Text="{Binding Password}" PasswordChar="*" Watermark="••••••••" 
                     Background="#313244" Foreground="#CDD6F4" BorderThickness="0" CornerRadius="8"/>

            <Button Content="Увійти" Command="{Binding LoginCommand}"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Background="#89B4FA" Foreground="#11111B" FontWeight="Bold" 
                    Padding="12" CornerRadius="8" Margin="0,20,0,0"/>
        </StackPanel>
        
    </Border>
</UserControl>