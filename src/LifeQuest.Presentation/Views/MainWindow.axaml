<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LifeQuest.Presentation.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
        x:Class="LifeQuest.Presentation.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Life Quest" 
        Width="900" Height="650"
        Background="#1E1E2E" FontFamily="Segoe UI">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto, *">
        <ScrollViewer Grid.Row="1" Margin="20">
            <StackPanel Spacing="15">
                <TextBlock Text="Активні Квести" FontSize="26" FontWeight="Bold" Foreground="#CDD6F4" Margin="0,10,0,10"/>
                
                <ItemsControl ItemsSource="{Binding ActiveQuests, Mode=OneWay}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#313244" CornerRadius="10" Padding="15" Margin="0,0,0,10">
                                <Grid ColumnDefinitions="*, Auto">
                                    <TextBlock Grid.Column="0" Text="{Binding Mode=OneWay}" FontSize="20" FontWeight="SemiBold" Foreground="#CDD6F4" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Content="Виконати" FontSize="16" FontWeight="Bold" Background="#A6E3A1" Foreground="#11111B" CornerRadius="8" Padding="15,10" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>